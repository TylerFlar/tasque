# tasque configuration — copy to `.env` and fill in.
#
# `.env` is auto-loaded by pydantic-settings (see src/tasque/config.py) and
# read by the various os.environ.get() call sites listed below. Every key is
# optional unless marked "REQUIRED". Unset keys fall back to the defaults
# shown.

# ---------------------------------------------------------------------------
# Core paths
# ---------------------------------------------------------------------------

# Where tasque stores its SQLite db, attachments, proxy logs, thread
# registry, and chain checkpointer file. Created on first use.
# Default: ~/.tasque
# DATA_DIR=/absolute/path/to/data

# Override the SQLite path explicitly. Defaults to <DATA_DIR>/tasque.db.
# DB_PATH=/absolute/path/to/tasque.db

# IANA tz name used by the scheduler for cron expressions on QueuedJobs and
# ChainTemplates.
# Default: UTC
# TASQUE_TIMEZONE=America/New_York

# Where Discord uploads land. Default: <DATA_DIR>/attachments.
# TASQUE_ATTACHMENTS_DIR=/absolute/path/to/attachments

# ---------------------------------------------------------------------------
# LLM proxy (`tasque proxy`)
# ---------------------------------------------------------------------------
# The proxy wraps a local model CLI as an OpenAI-compat endpoint. This
# is required: set TASQUE_PROXY_UPSTREAM=claude to use `claude --print`,
# or TASQUE_PROXY_UPSTREAM=codex to use `codex exec --json`.

# Upstream CLI to spawn. REQUIRED.
# TASQUE_PROXY_UPSTREAM=claude

# URL the daemon's ChatOpenAI clients hit. Must match the proxy's bind addr.
# Default: http://localhost:3456/v1
# TASQUE_PROXY_BASE_URL=http://localhost:3456/v1

# Placeholder API key. The proxy ignores it; ChatOpenAI just requires
# something non-empty. No reason to change this in normal use.
# Default: tasque-proxy-no-key
# TASQUE_PROXY_API_KEY=tasque-proxy-no-key

# Semaphore cap on concurrent upstream CLI invocations. Keep > 1 so
# nested LLM calls through MCPs that route back through the proxy don't
# deadlock.
# Default: 4
# TASQUE_PROXY_MAX_CONCURRENT=4

# Per-request raw stream-json transcripts. Files older than 7 days are
# pruned at startup.
# Default: data/proxy-logs (relative to cwd)
# TASQUE_PROXY_LOG_DIR=data/proxy-logs

# Override the cwd used to spawn the upstream CLI. Provider-specific
# variants win when set. Defaults to the tasque project root.
# TASQUE_PROXY_CWD=/absolute/path/to/tasque
# TASQUE_CLAUDE_CWD=/absolute/path/to/tasque
# TASQUE_CODEX_CWD=/absolute/path/to/tasque

# Codex runs with full filesystem access and no approval prompts via
# `--dangerously-bypass-approvals-and-sandbox`; the proxy is unattended.

# ---------------------------------------------------------------------------
# tasque MCP (`tasque mcp`)
# ---------------------------------------------------------------------------
# tasque ships its own stdio MCP server that exposes the daemon's state
# (notes, queued jobs, chain templates, chain runs, signals) as live
# tools. Register it in your host MCP config under mcpServers:
#
#   "tasque": {
#       "command": "uv",
#       "args": ["run", "--directory", "/abs/path/to/tasque", "tasque", "mcp"]
#   }
#
# With it registered, every upstream call routed through tasque proxy
# gets the tasque tool catalog — coaches, workers, and the
# strategist can all fire chains and queue jobs mid-turn instead of
# encoding every action in trailing JSON. There are no env knobs for
# the MCP itself; it reads the same DB_PATH / DATA_DIR as the daemon.

# ---------------------------------------------------------------------------
# Model selection
# ---------------------------------------------------------------------------
# Two paths, depending on agent kind:
#
# Coach + strategist (fixed-role) resolution priority (highest first):
#   1. TASQUE_MODEL_<KIND>  (tier alias or concrete model id)
#   2. TASQUE_MODEL_<TIER>  (tier alias -> concrete model id)
#   Both default to the large tier.
#
# Worker + chain planner: tier is chosen PER ROW (per QueuedJob.tier and
# per chain plan node / chain spec planner_tier). The agent-kind env
# overrides do not apply to them. Resolution is just:
#   1. TASQUE_MODEL_<TIER>  (tier override)
#   2. error if no model id is configured for that tier
#
# Tier aliases are provider-agnostic scheduling labels stored in the DB.
# Set their concrete model ids for the selected upstream.
# TASQUE_MODEL_LARGE=gpt-5.5
# TASQUE_MODEL_MEDIUM=gpt-5.4
# TASQUE_MODEL_SMALL=gpt-5.4-mini

# Per-agent overrides — pin coach or strategist to a specific model
# or a generic tier alias. (TASQUE_MODEL_WORKER and TASQUE_MODEL_PLANNER
# are intentionally not honoured; their tier is per-row.)
# TASQUE_MODEL_COACH=large
# TASQUE_MODEL_STRATEGIST=large

# ---------------------------------------------------------------------------
# Coach
# ---------------------------------------------------------------------------

# Post-claim dedup window for the coach trigger queue, in seconds. Two
# enqueues with the same (bucket, dedup_key) within this window after
# the first row was claimed collapse to one run. Pending rows dedup
# unconditionally regardless of this value. CLI `tasque coach wake`
# passes dedup_key=None and always enqueues.
# Default: 300 (5 minutes)
# TASQUE_COACH_DEDUP_SECONDS=300

# Override the shared coach scaffold path. Defaults to
# <repo>/prompts/coach_scaffold.md.
# TASQUE_COACH_SCAFFOLD=/absolute/path/to/coach_scaffold.md

# Override the per-bucket prompt directory. Each bucket reads
# <dir>/<bucket>.md. Defaults to <repo>/coach_prompts.
# TASQUE_COACH_PROMPT_DIR=/absolute/path/to/coach_prompts

# Override the conversational reply scaffold. Defaults to
# <repo>/prompts/coach_reply_scaffold.md.
# TASQUE_COACH_REPLY_SCAFFOLD=/absolute/path/to/coach_reply_scaffold.md

# ---------------------------------------------------------------------------
# Discord bot (`tasque serve`)
# ---------------------------------------------------------------------------

# Bot token from the Discord developer portal. REQUIRED to start the bot.
# TASQUE_DISCORD_TOKEN=

# All five Discord channel ids below are REQUIRED. There are no
# fallbacks — daemon startup fails fast if any of these is unset or
# unparseable. Each channel has a single, distinct purpose; do NOT
# point two of them at the same channel unless you want the streams
# interleaved.

# Coach channel — parent for the per-bucket coach threads. Reserved
# exclusively for user ↔ coach conversation. Chain status, approvals,
# and worker reports never land here.
# TASQUE_DISCORD_COACH_CHANNEL_ID=

# DLQ channel — failed-job entries (with Retry button) post here.
# TASQUE_DISCORD_DLQ_CHANNEL_ID=

# Jobs channel — worker-run embeds post here, and per-chain threads
# (for approval / ask-user prompts and any chain-side conversation)
# anchor here.
# TASQUE_DISCORD_JOBS_CHANNEL_ID=

# Ops-panel channel — hosts the single live-edited ops embed (jobs /
# chains / DLQ snapshot). The watcher posts one message and edits it
# every 30s; the message id is cached so daemon restarts reuse it.
# Pin the message manually for max visibility.
# TASQUE_DISCORD_OPS_CHANNEL_ID=

# Chains channel — every chain run gets ONE live-edited status embed
# here, refreshed as the run progresses (node start, fan-out,
# completion). The message id is persisted on the ChainRun row so
# daemon restarts don't spawn duplicates.
# TASQUE_DISCORD_CHAINS_CHANNEL_ID=

# Optional guild id (or comma-separated list) to register the `/status`
# slash command instantly to that guild during dev. Without this,
# slash commands are global and Discord may take up to an hour to
# propagate them.
# TASQUE_DISCORD_GUILD_ID=

# Path to the per-bucket / per-chain Discord thread registry JSON.
# Default: <DATA_DIR>/discord_threads.json
# TASQUE_DISCORD_THREAD_REGISTRY=/absolute/path/to/discord_threads.json
